{
    "name": "nexus/refmanager",
    "description": "Reference manager with Zotero, EndNote, and Mendeley import/export for Laravel",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "bibliography",
        "references",
        "ris",
        "bibtex",
        "csl-json",
        "endnote",
        "zotero",
        "mendeley",
        "citation",
        "academic",
        "references"
    ],
    "homepage": "https://github.com/nexus-scholar/refmanager",
    "readme": "README.md",
    "time": "2024-01-01",
    "support": {
        "issues": "https://github.com/nexus-scholar/refmanager/issues",
        "source": "https://github.com/nexus-scholar/refmanager"
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "renanbr/bibtex-parser": "^2.1"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\RefManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\RefManager\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-do": "phpunit --testdox"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nexus\\RefManager\\RefManagerServiceProvider"
            ],
            "aliases": {
                "RefImporter": "Nexus\\RefManager\\Facades\\RefImporter",
                "RefExporter": "Nexus\\RefManager\\Facades\\RefExporter"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
